# Server
PORT=4000
NODE_ENV=development

# Local DB (SQLite). For prod, point this at your RDS instance, e.g.
# DATABASE_URL=postgres://user:pass@host:5432/blood_bank
DATABASE_URL=sqlite:./blood_bank.sqlite

# AWS (used by services/notificationService.js when NODE_ENV=production)
AWS_REGION=us-east-1
SNS_TOPIC_ARN=
S3_BUCKET=

# Inventory threshold below which a low-stock alert is published
LOW_STOCK_THRESHOLD=5

# Minimum days between donations from the same donor (WHO guideline: 56)
DONATION_COOLDOWN_DAYS=56
